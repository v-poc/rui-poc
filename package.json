{
  "name": "rui-poc",
  "version": "0.4.23",
  "description": "The RUI POC - Mobile web UI components based on react-hooks and vite7",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/v-poc/rui-poc.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "npm run build && vite preview",
    "start": "vite"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">= 10"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "rollup": "4"
      }
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "less"
    ]
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.4",
    "axios": "^1.13.5",
    "less": "^4.5.1",
    "rui-next": "0.49.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-mock": "2.9.6"
  }
}
